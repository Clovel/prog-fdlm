# PostgreSQL connection string used by Drizzle on the server and by db:* scripts.
# Server-only — never prefix with NEXT_PUBLIC_.
DATABASE_URL=postgres://user:password@host:5432/database

# The events map uses MapLibre GL + IGN Géoplateforme vector tiles — keyless, no API key needed.

# Geocoding uses France's BAN via IGN's Géoplateforme — keyless, server-side. Optional override:
# GEOCODING_BASE_URL=https://data.geopf.fr/geocodage

# BetterAuth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Extra origins (comma-separated) trusted by the CSRF origin check, on top of
# BETTER_AUTH_URL. Add custom domains / Vercel preview URLs / localhost here.
TRUSTED_ORIGINS=http://localhost:3000,https://prog-fdlm.vercel.app

# Resend transactional email (password reset)
RESEND_API_KEY=
EMAIL_FROM=Fête de la Musique <onboarding@resend.dev>

# First-admin seed (consumed only by pnpm db:seed:admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=FDLM
