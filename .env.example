# PostgreSQL connection string used by Drizzle on the server and by db:* scripts.
# Server-only — never prefix with NEXT_PUBLIC_.
DATABASE_URL=postgres://user:password@host:5432/database

# Google Maps tile rendering (used by EventsMap)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Geocoding uses France's BAN (api-adresse.data.gouv.fr) — keyless, server-side. Optional override:
# GEOCODING_BASE_URL=https://api-adresse.data.gouv.fr

# BetterAuth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Resend transactional email (password reset)
RESEND_API_KEY=
EMAIL_FROM=Fête de la Musique <onboarding@resend.dev>

# First-admin seed (consumed only by pnpm db:seed:admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=FDLM
